# Copy this file to .env.vps on the VPS and replace both secrets.
POSTGRES_PASSWORD=replace-with-a-long-random-password
TWELVE_DATA_ENABLED=true
TWELVE_DATA_API_KEY=replace-with-your-twelve-data-key
GDELT_ENABLED=false

# The gateway binds only to VPS loopback. Connect with an SSH tunnel.
PROBORA_SSH_PORT=8090
